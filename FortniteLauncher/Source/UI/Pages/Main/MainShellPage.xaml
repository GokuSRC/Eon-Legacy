<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FortniteLauncher.Pages.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FortniteLauncher.Pages"
    xmlns:controls="using:CommunityToolkit.Labs.WinUI"
    NavigationCacheMode="Enabled">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="HeaderBorder" CornerRadius="8" Margin="0,0,0,4" Height="215">
            <Grid>
                <Image x:Name="BannerImage" Stretch="UniformToFill">
                    <Image.Source>
                        <BitmapImage UriSource="" CreateOptions="IgnoreImageCache"/>
                    </Image.Source>
                </Image>

                <Border x:Name="HeaderBlurBorder" CornerRadius="8" Background="Transparent"/>
            </Grid>
        </Border>

        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Border Padding="8" x:Name="HeaderProfileBanner">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="ProfileContainer" Grid.Column="0" VerticalAlignment="Center">
                        <Border x:Name="BlurredBackground" Width="96" Height="96" CornerRadius="20" Background="Gray" Opacity="0.1"/>
                        <Border Width="96" Height="96" CornerRadius="20">
                            <Border.Background>
                                <ImageBrush x:Name="ProfileImageBrush">
                                    <ImageBrush.Transform>
                                        <ScaleTransform ScaleX="1" CenterX="100"/>
                                    </ImageBrush.Transform>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <TeachingTip x:Name="DownloadInfo"
                                 Title="Downloading Required Files"
                                 Subtitle="{x:Bind Progress}"
                                 FontWeight="SemiBold">
                        <TeachingTip.IconSource>
                            <SymbolIconSource Symbol="Download"/>
                        </TeachingTip.IconSource>
                    </TeachingTip>

                    <StackPanel VerticalAlignment="Center" Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock Text="{x:Bind DisplayUsername, Mode=OneWay}" 
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Style="{ThemeResource TitleTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind Description, Mode=OneWay}" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,1,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="2" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Height="96" 
                            Width="180" 
                            CornerRadius="12" 
                            Margin="0,0,16,0">
                        <Image Source="https://i.pinimg.com/736x/27/cd/69/27cd69ca3167966ecb560a4c3d107850.jpg" 
                               Stretch="UniformToFill"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:SettingsCard x:Name="DonationsCard"
                                   Grid.Column="0"
                                   Header="Donations"
                                   Description="Contribute to the community and unlock exclusive perks."
                                   Click="Donations"
                                   FontWeight="SemiBold">
                <controls:SettingsCard.HeaderIcon>
                    <ImageIcon Source="ms-appx:///Content/Texture/UI/T_Donate.png"/>
                </controls:SettingsCard.HeaderIcon>
                <Button x:Name="DonationsButton" 
                        Click="Donations" 
                        Content="Donate"
                        FontWeight="SemiBold"/>
            </controls:SettingsCard>

            <controls:SettingsCard x:Name="TiktokCard"
                                   Grid.Column="2"
                                   Header="Tiktok"
                                   Description="Follow us for sneak peeks and exclusive content."
                                   Click="Tiktok"
                                   FontWeight="SemiBold">
                <controls:SettingsCard.HeaderIcon>
                    <ImageIcon Source="ms-appx:///Content/Texture/UI/T_Tiktok.png"/>
                </controls:SettingsCard.HeaderIcon>
                <Button x:Name="TiktokButton" 
                        Click="Tiktok" 
                        Content="View"
                        FontWeight="SemiBold"/>
            </controls:SettingsCard>
        </Grid>

        <controls:SettingsCard x:Name="LaunchButton"
                               x:FieldModifier="public"
                               Grid.Row="2"
                               Tag="Launch"
                               Header="{x:Bind local:PlayPage.Season, Mode=OneTime}"
                               Description="{x:Bind local:PlayPage.Chapter, Mode=OneTime}"
                               Margin="4,2,4,24"
                               IsClickEnabled="True"
                               IsActionIconVisible="False"
                               Click="Launch"
                               FontWeight="SemiBold">
            <controls:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE768;"/>
            </controls:SettingsCard.HeaderIcon>
        </controls:SettingsCard>

        <StackPanel Grid.Row="3" Margin="4,0,4,0" Spacing="6" HorizontalAlignment="Left" VerticalAlignment="Bottom">
            <TextBlock Text="updates and news" 
                       FontSize="22" 
                       FontFamily="Consolas"
                       FontWeight="Normal" 
                       Foreground="White"/>

            <TextBlock Text="we are updating eon+ 24/7" 
                       FontSize="16" 
                       FontFamily="Consolas"
                       Foreground="#EAEAEA"
                       Margin="0,0,0,4"/>

            <MenuFlyoutSeparator Background="Gray" Margin="0,4,0,16" Width="340" HorizontalAlignment="Left"/>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="31/05/26" 
                           FontSize="18" 
                           FontFamily="Consolas"
                           FontWeight="Normal" 
                           Foreground="White"/>

                <TextBlock Text="|" 
                           FontSize="18" 
                           FontFamily="Consolas"
                           Foreground="Gray"/>

                <TextBlock Text="RELEASE OF EON+" 
                           FontSize="18" 
                           FontFamily="Consolas"
                           FontWeight="SemiBold" 
                           Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>